<Window x:Class="PP11.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PP11"
        mc:Ignorable="d"
        Title="LoginWindow" Height="450" Width="400" MaxHeight="500" MaxWidth="400" MinHeight="450" MinWidth="400">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="1.5*"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="0.1*"/>
            <RowDefinition Height="0.5*"/>
            <RowDefinition Height="0.5*"/>
            <RowDefinition Height="0.5*"/>
            <RowDefinition Height="0.2*"/>
            <RowDefinition Height="0.4*"/>
        </Grid.RowDefinitions>

        <Label Grid.Column="0" Grid.Row="0" Grid.ColumnSpan="4" Content="Система аварийных заявок"
               HorizontalAlignment="Center" VerticalAlignment="Center" 
               FontFamily="Sitka Text" FontSize="22" FontWeight="Bold"
               Background="#006CB5" Foreground="White" 
               MinHeight="80" MinWidth="360" 
               HorizontalContentAlignment="Center"  VerticalContentAlignment="Center"/>

        <Label Content="Вход в систему" Grid.Column="0" Grid.Row="0" Grid.ColumnSpan="4"
       Foreground="#006CB5" 
       FontSize="20" FontWeight="Bold"
       VerticalAlignment="Bottom" HorizontalAlignment="Center"
       Margin="-5"/>
        <Label Grid.Column="0" Grid.Row="2" Content="Логин"
               HorizontalAlignment="Right" VerticalAlignment="Center"
               FontFamily="Sitka Text" FontSize="16" FontWeight="Bold"
               />

        <TextBox Name="LoginTextBox" Grid.Column="1" Grid.Row="2" Grid.ColumnSpan="3" Margin="10,15,10,15"
                 Background="#E0E0E0" BorderBrush="Transparent" VerticalContentAlignment="Center"
                 />

        <Label Grid.Column="0" Grid.Row="3" Content="Пароль"
               HorizontalAlignment="Right" VerticalAlignment="Center"
               FontFamily="Sitka Text" FontSize="16" FontWeight="Bold"
               />

        <PasswordBox Name="PasswordPasswordBox" Grid.Column="1" Grid.Row="3" Grid.ColumnSpan="3" Margin="10,15,10,15"
                 Background="#E0E0E0" BorderBrush="Transparent" VerticalContentAlignment="Center"
                 />

        <Button Grid.Column="0" Grid.Row="4" Grid.ColumnSpan="4" Margin="50,20,50,10"
                Content="Войти" FontSize="16"
                Background="#006CB5" Foreground="#E0E0E0" BorderBrush="Transparent"
                Click="EnterButton_Click"
                MouseEnter="Button_MouseEnter" Name="ENterButton"
                MouseLeave="ENterButton_MouseLeave"/>

        
            <Label Content="Нет аккаунта?" FontSize="14" Margin="0,-2,0,0" Foreground="#FF868686" Grid.Column="0" Grid.Row="5"
                   Grid.ColumnSpan="2" HorizontalAlignment="Right"/>
            
            <Label Content="Зарегистрироваться" FontSize="14" Margin="0,-2,0,0" Foreground="#006CB5"
                   Grid.Column="2" Grid.Row="5" Grid.ColumnSpan="2"
                   MouseLeftButtonDown="Reg_MouseLeftButtonDown"
                   MouseEnter="Label_MouseEnter" Name="regLabel"
                   MouseLeave="regLabel_MouseLeave"/>
        

        <Label Name="ErrorLabel" Content="" Grid.Column="0" Grid.Row="6" Grid.ColumnSpan="4" Margin="0,-10,0,0"
               HorizontalAlignment="Center" VerticalAlignment="Center" 
               Foreground="Red" FontWeight="Bold" FontSize="12"/>


    </Grid> 
</Window>
