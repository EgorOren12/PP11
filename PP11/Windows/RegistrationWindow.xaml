<Window x:Class="PP11.RegistrationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PP11"
        mc:Ignorable="d"
        Title="RegistrationWindow" Height="570" Width="400" MaxHeight="570" MaxWidth="400" MinHeight="570" MinWidth="400">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="4*"/>
            <RowDefinition Height="0.5*"/>
            <RowDefinition Height="1.2*"/>
            <RowDefinition Height="1.2*"/>
            <RowDefinition Height="1.2*"/>
            <RowDefinition Height="1.2*"/>
            <RowDefinition Height="1.2*"/>
            <RowDefinition Height="1.2*"/>
            <RowDefinition Height="1.2*"/>
            <RowDefinition Height="2.4*"/>
            <RowDefinition Height="1.2*"/>
            <RowDefinition Height="1.2*"/>
        </Grid.RowDefinitions>
        <StackPanel Grid.Column="0" Grid.Row="0" Grid.ColumnSpan="4">
            <Label  Content="Система аварийных заявок"
               HorizontalAlignment="Center" VerticalAlignment="Center" 
               FontFamily="Sitka Text" FontSize="22" FontWeight="Bold"
               Background="#006CB5" Foreground="White" 
               MinHeight="80" MinWidth="360" 
               HorizontalContentAlignment="Center"  VerticalContentAlignment="Center"
                   Margin="0,10,0,0"/> 

            <Label Content="Регистрация" 
               Foreground="#006CB5" 
               FontSize="20" FontWeight="Bold"
               VerticalAlignment="Bottom" HorizontalAlignment="Center"
                   Margin="0,-5,0,0"
               />
        </StackPanel>
        

        <Label Content="ФИО" Grid.Row="2" Grid.Column="0"
               HorizontalAlignment="Right" VerticalAlignment="Center"
                FontFamily="Sitka Text" FontSize="16" FontWeight="Bold"/>

        <TextBox Name="FIOTextBox" Grid.Column="1" Grid.Row="2" Grid.ColumnSpan="3" Margin="10,5,10,5"
                 Background="#E0E0E0" BorderBrush="Transparent" VerticalContentAlignment="Center"
                 />

        <Label Content="Логин" Grid.Row="3" Grid.Column="0"
               HorizontalAlignment="Right" VerticalAlignment="Center"
                FontFamily="Sitka Text" FontSize="16" FontWeight="Bold"/>

        <TextBox Name="LoginTextBox" Grid.Column="1" Grid.Row="3" Grid.ColumnSpan="3" Margin="10,5,10,5"
         Background="#E0E0E0" BorderBrush="Transparent" VerticalContentAlignment="Center"
         />

        <Label Content="Пароль" Grid.Row="4" Grid.Column="0"
                HorizontalAlignment="Right" VerticalAlignment="Center"
                FontFamily="Sitka Text" FontSize="16" FontWeight="Bold"/>

        <PasswordBox Name="PasswordPasswordBox" Grid.Column="1" Grid.Row="4" Grid.ColumnSpan="3" Margin="10,5,10,5"
                Background="#E0E0E0" BorderBrush="Transparent" VerticalContentAlignment="Center"
         />

        <TextBlock Text="Повторите пароль" Grid.Row="5" Grid.Column="0"
                HorizontalAlignment="Right" VerticalAlignment="Center"
                TextAlignment="Right"
                FontFamily="Sitka Text" FontSize="16" FontWeight="Bold"
                   TextWrapping="Wrap"
                   />

        <PasswordBox Name="Password2PasswordBox" Grid.Column="1" Grid.Row="5" Grid.ColumnSpan="3" Margin="10,5,10,5"
                 Background="#E0E0E0" BorderBrush="Transparent" VerticalContentAlignment="Center"
 />

        <Label Content="Роль" Grid.Row="6" Grid.Column="0"
                HorizontalAlignment="Right" VerticalAlignment="Center"
                FontFamily="Sitka Text" FontSize="16" FontWeight="Bold"/>
        
        <ComboBox Grid.Row="6" Grid.Column="1" Grid.ColumnSpan="3" Margin="10,5,10,5"
                  Background="#E0E0E0" BorderBrush="Transparent" VerticalContentAlignment="Center"
                  Name="RolesComboBox"/>

        <Label Content="Филиал" Grid.Row="7" Grid.Column="0"
                    HorizontalAlignment="Right" VerticalAlignment="Center"
                    FontFamily="Sitka Text" FontSize="16" FontWeight="Bold"/>
        
        <ComboBox Grid.Row="7" Grid.Column="1" Grid.ColumnSpan="3" Margin="10,5,10,5"
                  Background="#E0E0E0" BorderBrush="Transparent" VerticalContentAlignment="Center"
                  Name="FilialComboBox"/>

        <Label Content="Эл.Почта" Grid.Row="8" Grid.Column="0"
            HorizontalAlignment="Right" VerticalAlignment="Center"
            FontFamily="Sitka Text" FontSize="16" FontWeight="Bold"/>

        <TextBox Name="EmailTextBox" Grid.Column="1" Grid.Row="8" Grid.ColumnSpan="3" Margin="10,5,10,5"
            Background="#E0E0E0" BorderBrush="Transparent" VerticalContentAlignment="Center"/>

        <Button Grid.Column="0" Grid.Row="9" Grid.ColumnSpan="4" Margin="50,20,50,10"
            Content="Войти" FontSize="16"
            Background="#006CB5" Foreground="#E0E0E0" BorderBrush="Transparent"
            Click="RegistrButton_Click"
            MouseEnter="RegistrButton_MouseEnter"  Name="RegistrButton"
            MouseLeave="RegistrButton_MouseLeave"/>

        <Label Content="Есть аккаунт?" FontSize="14" Margin="0,-2,0,0" Foreground="#FF868686" Grid.Column="0" Grid.Row="10"
       Grid.ColumnSpan="2" HorizontalAlignment="Right"/>

        <Label Content="Войдите" FontSize="14" Margin="0,-2,0,0" Foreground="#006CB5"
               Grid.Column="2" Grid.Row="10" Grid.ColumnSpan="2"
               MouseLeftButtonDown="EnterLabel_MouseLeftButtonDown"
               MouseEnter="EnterLabel_MouseEnter"  Name="EnterLabel"
               MouseLeave="EnterLabel_MouseLeave"/>

        <Label Name="ErrorLabel" Content="" Grid.Column="0" Grid.Row="11" Grid.ColumnSpan="4" Margin="0,-10,0,0"
               HorizontalAlignment="Center" VerticalAlignment="Center" 
               Foreground="Red" FontWeight="Bold" FontSize="12"/>
    </Grid>

</Window>
